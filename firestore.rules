rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return (isAuthenticated() && request.auth.uid == userId) || userId == 'local_user';
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "adrien.brunelliere@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isBecomingAdmin() {
      return request.resource.data.get('role', '') == 'admin';
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields([
        'userName', 'firstName', 'lastName', 'jobTitle', 'contractType', 
        'hoursBase', 'contractStartDate', 'autoGeo', 'onboarded', 
        'shifts', 'logs', 'role', 'qualifications', 'entryDate', 'workRegime',
        'monthlyHours', 'leaveCalculation',
        'updatedAt', 'hasDea', 'hasAux', 'hasTaxiCard', 'profileImage',
        'hourlyRate', 'companyName', 'companyCity', 'primaryGraduationDate', 'deaDate',
        'auxDate', 'taxiDate', 'taxiCardExpiryDate', 'taxiFpcDate',
        'afgsuDate', 'medicalExpiryDate', 'cpCalculationMode',
        'modulationStartDate', 'modulationWeeks', 'initialCpBalance',
        'weeklyContractHours', 'overtimeMode', 'payRateMode',
        'pushEnabled', 'followSystemTheme', 'customHours',
        'email', 'createdAt', 'roles', 'primaryRole',
        'activeShiftId', 'scheduledShiftId'
      ]) &&
      (!('userName' in data) || (data.userName is string && data.userName.size() < 100)) &&
      (!('firstName' in data) || (data.firstName is string && data.firstName.size() < 100)) &&
      (!('lastName' in data) || (data.lastName is string && data.lastName.size() < 100)) &&
      (!('companyName' in data) || (data.companyName is string && data.companyName.size() < 200)) &&
      (!('jobTitle' in data) || (data.jobTitle is string && data.jobTitle.size() < 100)) &&
      (!('onboarded' in data) || (data.onboarded is bool)) &&
      (!('roles' in data) || (data.roles is list)) &&
      (!('primaryRole' in data) || (data.primaryRole is string)) &&
      (!('weeklyContractHours' in data) || (data.weeklyContractHours is number)) &&
      (!('overtimeMode' in data) || (data.overtimeMode is string)) &&
      (!('payRateMode' in data) || (data.payRateMode is string));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data) && (!isBecomingAdmin() || isAdmin());
    }

    match /test/{docId} {
      allow read: if true;
    }

    match /shifts/{shiftId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}
