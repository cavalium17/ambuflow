{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and configuration",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "profileImage": { "type": "string", "description": "Base64 or URL" },
        "jobTitle": { "type": "string" },
        "qualifications": { "type": "array", "items": { "type": "string" } },
        "entryDate": { "type": "string" },
        "workRegime": { "type": "string" },
        "modulationWeeks": { "type": "string" },
        "monthlyHours": { "type": "string" },
        "leaveCalculation": { "type": "string" },
        "hourlyRate": { "type": "string" },
        "companyName": { "type": "string" },
        "companyCity": { "type": "string" },
        "autoGeo": { "type": "boolean" },
        "hasDea": { "type": "boolean" },
        "hasAux": { "type": "boolean" },
        "hasTaxiCard": { "type": "boolean" },
        "primaryGraduationDate": { "type": "string" },
        "deaDate": { "type": "string" },
        "auxDate": { "type": "string" },
        "taxiDate": { "type": "string" },
        "taxiCardExpiryDate": { "type": "string" },
        "taxiFpcDate": { "type": "string" },
        "afgsuDate": { "type": "string" },
        "medicalExpiryDate": { "type": "string" },
        "contractStartDate": { "type": "string" },
        "contractType": { "type": "string" },
        "hoursBase": { "type": "string" },
        "cpCalculationMode": { "type": "string" },
        "modulationStartDate": { "type": "string" },
        "initialCpBalance": { "type": "number" },
        "weeklyContractHours": { "type": "number" },
        "overtimeMode": { "type": "string", "enum": ["weekly", "biweekly", "modulation", "annualized"] },
        "modulationWeeks": { "type": "number" },
        "payRateMode": { "type": "string", "enum": ["100_percent", "90_percent"] },
        "customHours": { "type": "string" },
        "followSystemTheme": { "type": "boolean" },
        "pushEnabled": { "type": "boolean" },
        "shifts": { "type": "array", "items": { "type": "object" } },
        "logs": { "type": "array", "items": { "type": "object" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName"]
    },
    "Shift": {
      "title": "Shift",
      "description": "Work shift record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "breakTime": { "type": "number" },
        "type": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "startTime", "endTime", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/shifts/{shiftId}": {
      "schema": "Shift",
      "description": "Work shifts"
    }
  }
}
